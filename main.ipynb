import google.generativeai as genai
import textwrap
import time
import sys

# 1. SETUP
API_KEY = "API KEY"
genai.configure(api_key=API_KEY)

# Using the stable alias found in the list
MODEL_NAME = 'models/gemini-flash-latest'
model = genai.GenerativeModel(MODEL_NAME)

def call_gemini_with_retry(prompt, max_retries=3):
    """Calls the API and retries if it hits a rate limit (429)."""
    for i in range(max_retries):
        try:
            response = model.generate_content(prompt)
            return response.text
        except Exception as e:
            if "429" in str(e):
                print(f"   (Rate limit hit. Waiting {i*5 + 5} seconds to retry...)")
                time.sleep(i*5 + 5)
            else:
                return f"ERROR: {str(e)}"
    return "ERROR: Max retries reached. Please wait a minute and try again."

def analyze_and_refine(user_prompt):
    """Logic to evaluate the prompt quality."""
    analysis_meta_prompt = f"""
    Act as a Prompt Engineering Expert.
    User Input: "{user_prompt}"

    Task: If the user input is shorter than 5 words or very broad, rate it BAD.

    Response format:
    RATING: [GOOD or BAD]
    REASON: [Why it needs improvement]
    REFINED_PROMPT: [A highly detailed, 1-sentence prompt based on the user's intent]
    """
    return call_gemini_with_retry(analysis_meta_prompt)

def run_demonstration():
    print("="*50)
    print("🌟 PROMPT REFINEMENT DEMONSTRATION SYSTEM 🌟")
    print("="*50)

    user_input = input("\nEnter your prompt (e.g., 'write about dogs'): ")
    if not user_input.strip(): return

    print("\n[Step 1] Analyzing prompt quality...")
    analysis = analyze_and_refine(user_input)

    if "ERROR" in analysis:
        print(analysis)
        return

    # Checking if the AI thinks it's BAD
    if "RATING: BAD" in analysis.upper():
        print("\n⚠️  WARNING: POOR PROMPT DETECTED")

        # Parsing the AI's suggestions
        try:
            reason = analysis.split("REASON:")[1].split("REFINED_PROMPT:")[0].strip()
            refined = analysis.split("REFINED_PROMPT:")[1].strip()

            print(f"❌ Issue: {reason}")
            print(f"✅ Auto-Updating Prompt to: {refined}")

            print("\n[Step 2] Generating answer using the updated prompt...")
            # Pause to prevent 429
            time.sleep(2)
            final_answer = call_gemini_with_retry(refined)
        except:
            print("\nUpdating prompt and generating answer...")
            final_answer = call_gemini_with_retry(user_input)
    else:
        print("\n✅ PROMPT ACCEPTED: Your prompt is detailed enough.")
        print("[Step 2] Generating answer...")
        final_answer = call_gemini_with_retry(user_input)

    print("\n" + "="*50)
    print("FINAL OUTPUT:")
    print("="*50)
    if "ERROR" in final_answer:
        print(final_answer)
    else:
        print(textwrap.fill(final_answer, width=80))
    print("="*50)

# Starting the system
run_demonstration()
